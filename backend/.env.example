# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,127.0.0.1,localhost
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# JWT
JWT_ACCESS_TOKEN_MINUTES=10080
JWT_REFRESH_TOKEN_DAYS=30
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
JWT_UPDATE_LAST_LOGIN=False

# DRF throttling
DRF_ANON_THROTTLE_RATE=100/hour
DRF_USER_THROTTLE_RATE=1000/hour
DRF_LOGIN_THROTTLE_RATE=5/min
DRF_RECOMMENDATION_THROTTLE_RATE=20/hour

# Database selector
# Use "sqlite" for local development.
# Use "postgresql" for production.
DB_ENGINE=sqlite

# SQLite development uses backend/db.sqlite3 automatically.

# PostgreSQL production settings
POSTGRES_DB=ab_medical_assistance
POSTGRES_USER=ab_medical_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
